 namespace onnxruntime {
 namespace openvino_ep {
 
+namespace {
+inline void AppendFormat(std::ostringstream& stream, std::string_view fmt) {
+  stream << fmt;
+}
+
+template <typename T, typename... Args>
+void AppendFormat(std::ostringstream& stream, std::string_view fmt, T&& value, Args&&... args) {
+  const auto placeholder_pos = fmt.find("{}");
+  if (placeholder_pos == std::string_view::npos) {
+    stream << fmt;
+    return;
+  }
+
+  stream << fmt.substr(0, placeholder_pos) << std::forward<T>(value);
+  AppendFormat(stream, fmt.substr(placeholder_pos + 2), std::forward<Args>(args)...);
+}
+
+template <typename... Args>
+std::string FormatMessage(std::string_view fmt, Args&&... args) {
+  std::ostringstream stream;
+  AppendFormat(stream, fmt, std::forward<Args>(args)...);
+  return stream.str();
+}
+}  // namespace
